# RESTAURANT VITRA NAGOYA — Environment Variables

# Contact form: email destination (use Resend, Nodemailer, or EmailJS)
CONTACT_EMAIL_TO=info@vitra-nagoya.jp

# Resend API key (https://resend.com) — for contact form email delivery
RESEND_API_KEY=

# Google Maps embed API key (optional — basic iframe embed works without one)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Canonical site URL
NEXT_PUBLIC_SITE_URL=https://nagoya.vitra.jp
